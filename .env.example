# Zettelkasten MCP Server Configuration

ZETTELKASTEN_NOTES_DIR=./data/notes
ZETTELKASTEN_DATABASE_PATH=./data/db/zettelkasten.db
ZETTELKASTEN_LOG_LEVEL=INFO

# FTS5 Full-Text Search (porter stemming, BM25 ranking)
USE_FTS5_SEARCH=true

# LLM Summary Generation (Azure OpenAI via DefaultAzureCredential)
# Set LLM_ENABLE_SUMMARIES=true and configure your Azure endpoint to enable.
LLM_ENABLE_SUMMARIES=false
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=300
