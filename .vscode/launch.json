{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug MCP Server",
            "type": "debugpy",
            "request": "launch",
            "module": "zettelkasten_mcp",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "ZETTELKASTEN_LOG_LEVEL": "DEBUG"
            },
            "args": [],
            "justMyCode": false,
            "preLaunchTask": "Install Dependencies"
        },
        {
            "name": "Debug Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "justMyCode": true
        },
        {
            "name": "Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "args": [
                "-v",
                "--tb=short",
                "${workspaceFolder}/tests"
            ],
            "justMyCode": false
        },
        {
            "name": "Debug Current Test File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "args": [
                "-v",
                "--tb=short",
                "${file}"
            ],
            "justMyCode": false
        },
        {
            "name": "Debug MCP Server with Test Data",
            "type": "debugpy",
            "request": "launch",
            "module": "zettelkasten_mcp",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "ZETTELKASTEN_LOG_LEVEL": "DEBUG",
                "ZETTELKASTEN_NOTES_DIR": "${workspaceFolder}/data/notes",
                "ZETTELKASTEN_DATABASE_PATH": "${workspaceFolder}/data/db/zettelkasten.db"
            },
            "args": [],
            "justMyCode": false,
            "preLaunchTask": "Install Dependencies"
        },
        {
            "name": "Attach to MCP Server",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "port": 5678,
                "host": "localhost"
            },
            "justMyCode": false,
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/src",
                    "remoteRoot": "/app/src"
                }
            ]
        }
    ]
}
